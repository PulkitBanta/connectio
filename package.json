{
  "name": "connectio",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Pulkit Banta",
    "email": "pulkitbanta@gmail.com"
  },
  "description": "A local proxy manager — connect and route between local servers with optional Cloudflare tunnel exposure",
  "main": "src/main.js",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.2"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "build": {
    "appId": "com.connectio.app",
    "productName": "Connectio",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network",
      "maintainer": "Pulkit Banta <pulkitbanta@gmail.com>"
    }
  },
  "dependencies": {
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5"
  }
}
