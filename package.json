{
  "name": "connectio",
  "version": "1.0.0",
  "license": "MIT",
  "author": {
    "name": "Pulkit Banta",
    "email": "pulkitbanta@gmail.com"
  },
  "description": "A local proxy manager — connect and route between local servers with optional Cloudflare tunnel exposure",
  "main": "out/main/index.js",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "solid-js": "^1.9.13",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.12"
  },
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build:css": "tailwindcss -i src/renderer/styles/tailwind.css -o src/renderer/styles/output.css",
    "build": "electron-vite build && electron-builder",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "build": {
    "appId": "com.connectio.app",
    "productName": "Connectio",
    "directories": {
      "output": "dist"
    },
    "icon": "icons",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icons/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "maintainer": "Pulkit Banta <pulkitbanta@gmail.com>"
    }
  },
  "dependencies": {
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.0.0"
  }
}
